{
  // The design system's nx: theme runs as a SEPARATE Tailwind compilation
  // (app/nexus.css) so its prefix can't clobber the app's own Tailwind at build
  // time. But the editor's Tailwind IntelliSense builds completions from ONE
  // design system per file and can't merge two entries
  // (tailwindcss-intellisense#665) — and two `@import "tailwindcss"` with
  // different prefixes collapse to one prefix, so it can't see both sets either.
  //
  // Fix: point IntelliSense at a single COMBINED design system that is generated
  // from @acme/tailwind — app default Tailwind + a no-op `nx` variant + the DS
  // tokens/utilities. It is IntelliSense-only (never imported at runtime), so
  // autocomplete + hover cover `bg-slate-*` AND the full `nx:` vocabulary
  // (colors, typography, roles, shadow, radius) with the design system's values.
  //
  // Generated by `node scripts/gen-intellisense-css.mjs` (also run by setup.mjs).
  // Requires Tailwind CSS IntelliSense v0.14.3+. Open this folder
  // (examples/nextjs-consumer) as the workspace root for it to apply.
  "tailwindCSS.experimental.configFile": {
    "tailwind.intellisense.css": "app/**"
  }
}
