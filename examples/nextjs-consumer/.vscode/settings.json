{
  // The design system's nx: theme runs as a SEPARATE Tailwind compilation
  // (app/nexus.css) so its prefix can't clobber the app's own Tailwind at build
  // time. Point Tailwind IntelliSense at that entry so `nx:` classes get
  // complete autocomplete + hover (colors, typography, shadow, radius — all with
  // the design system's values).
  //
  // Trade-off (Tailwind's one-prefix-per-design-system limit + the extension not
  // merging two entries per file — tailwindcss-intellisense#665): while this is
  // active, your app's OWN unprefixed utilities (bg-slate-*, flex, …) won't
  // autocomplete. They're standard Tailwind; the `nx:` vocabulary is the part
  // worth completion help.
  //
  // Requires Tailwind CSS IntelliSense v0.14.3+ (v4 CSS-config support). Open
  // this folder (examples/nextjs-consumer) as the workspace root for it to apply.
  "tailwindCSS.experimental.configFile": {
    "app/nexus.css": "app/**"
  }
}
