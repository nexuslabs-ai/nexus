{
  "name": "design-system",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "eslint . --max-warnings 0",
    "test": "yarn workspace @nexus/react generate:base-variants && vitest run",
    "test:watch": "yarn workspace @nexus/react generate:base-variants && vitest",
    "test:unit": "vitest run --project=unit",
    "test:storybook": "yarn workspace @nexus/react generate:base-variants && vitest run --project=storybook",
    "test:storybook:watch": "yarn workspace @nexus/react generate:base-variants && vitest --project=storybook",
    "test:storybook:ui": "yarn workspace @nexus/react generate:base-variants && vitest --project=storybook --ui",
    "storybook": "yarn workspace @nexus/react storybook",
    "build-storybook": "yarn workspace @nexus/react build-storybook",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css,yml}\" \".claude/**/*.md\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css,yml}\" \".claude/**/*.md\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "typecheck": "turbo run typecheck",
    "tokens:modular": "yarn workspace @nexus/core build:tokens:modular && node scripts/sync-console-themes.js && node scripts/sync-docs-themes.js",
    "tokens:tailwind": "cd packages/core && yarn build:tailwind && cp dist/tailwind/* ../../packages/tailwind/",
    "audit:contrast": "yarn workspace @nexus/core audit:contrast",
    "audit:storybook-coverage": "yarn workspace @nexus/react audit:storybook-coverage",
    "validate:spacing-modes": "yarn workspace @nexus/core validate:spacing-modes",
    "console": "cd apps/console && yarn dev",
    "size-limit": "size-limit",
    "prepare": "husky"
  },
  "size-limit": [
    {
      "name": "@nexus/react (ESM)",
      "path": "packages/react/dist/index.mjs",
      "ignore": [
        "react-hook-form",
        "sonner"
      ],
      "limit": "80 kB"
    },
    {
      "name": "@nexus/react (CSS)",
      "path": "packages/react/dist/react.css",
      "limit": "30 kB"
    }
  ],
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@nexus/eslint-plugin": "*",
    "@size-limit/preset-small-lib": "^12.0.0",
    "@storybook/addon-vitest": "^10.1.11",
    "@vitest/browser": "4.0.18",
    "@vitest/browser-playwright": "4.0.18",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jsdom": "^27.3.0",
    "jsonc-eslint-parser": "^3.1.0",
    "lint-staged": "^16.2.7",
    "playwright": "^1.57.0",
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "size-limit": "^12.0.0",
    "turbo": "^2.7.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.0",
    "vitest": "4.0.18"
  },
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": ">=20.19.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ],
    "packages/core/tokens/semantic/spacing-*.json": [
      "yarn validate:spacing-modes",
      "eslint --fix --no-warn-ignored"
    ]
  },
  "//resolutions": "zod is pinned to dedupe @hookform/resolvers' broad peer range (^3.25.0 || ^4.0.0) onto a single v4 copy, so zodResolver() typechecks in Form.stories.tsx. zod is a story-only devDependency and ships in no package bundle.",
  "resolutions": {
    "minimatch": "^10.1.2",
    "zod": "^4.4.3"
  }
}
