{
  "name": "design-system",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --project=unit",
    "typecheck:dist": "pnpm --filter @nexus_ds/core typecheck:dist-core && node scripts/typecheck-tailwind-dist.mjs",
    "test:storybook": "vitest run --project=storybook",
    "test:storybook:watch": "vitest --project=storybook",
    "test:storybook:ui": "vitest --project=storybook --ui",
    "storybook": "pnpm --filter @nexus_ds/react storybook",
    "build-storybook": "pnpm --filter @nexus_ds/react build-storybook",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css,yml}\" \".claude/**/*.md\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css,yml}\" \".claude/**/*.md\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "typecheck": "turbo run typecheck",
    "tokens:modular": "pnpm --filter @nexus_ds/core build:tokens:modular && node scripts/sync-docs-themes.js",
    "tokens:tailwind": "cd packages/core && pnpm build:tailwind && cp dist/tailwind/* ../../packages/tailwind/",
    "audit:browser-support": "node scripts/audit-browser-support.js",
    "audit:agent-drift": "node scripts/audit-agent-drift.js",
    "audit:contrast": "pnpm --filter @nexus_ds/core audit:contrast",
    "audit:mode-codenames": "pnpm --filter @nexus_ds/core audit:mode-codenames",
    "audit:mode-distinctness": "pnpm --filter @nexus_ds/core audit:mode-distinctness",
    "validate:spacing-modes": "pnpm --filter @nexus_ds/core validate:spacing-modes",
    "console": "cd apps/console && pnpm dev",
    "docs:serve": "npx @arabold/docs-mcp-server@latest server --store-path ./docs-mcp/data --protocol http --host 127.0.0.1 --port 6282",
    "docs:export": "cp ./docs-mcp/data/documents.db ./docs-mcp/documents.db && echo 'Exported docs-mcp database to docs-mcp/documents.db'",
    "docs:build": "docker build -t ghcr.io/nexuslabs-ai-bot/nexus-docs-mcp:latest ./docs-mcp",
    "docs:login": "gh auth token --user nexuslabs-ai-bot | docker login ghcr.io -u nexuslabs-ai-bot --password-stdin",
    "docs:push": "docker push ghcr.io/nexuslabs-ai-bot/nexus-docs-mcp:latest",
    "docs:publish": "pnpm run docs:export && pnpm run docs:build && pnpm run docs:push",
    "docs:start": "docker rm -f -v nexus-docs-mcp >/dev/null 2>&1; docker run -d --rm --name nexus-docs-mcp -p 6282:6282 ghcr.io/nexuslabs-ai-bot/nexus-docs-mcp:latest --protocol http --host 0.0.0.0 --port 6282 && echo 'Docs MCP server running at http://localhost:6282'",
    "docs:stop": "docker stop nexus-docs-mcp",
    "docs:pull": "docker pull ghcr.io/nexuslabs-ai-bot/nexus-docs-mcp:latest",
    "docs:restore": "docker rm -f -v nexus-docs-restore >/dev/null 2>&1; docker create --name nexus-docs-restore ghcr.io/nexuslabs-ai-bot/nexus-docs-mcp:latest >/dev/null && docker cp nexus-docs-restore:/data/documents.db ./docs-mcp/data/documents.db && docker rm -v nexus-docs-restore >/dev/null && rm -f ./docs-mcp/data/documents.db-wal ./docs-mcp/data/documents.db-shm && echo 'Restored docs-mcp database from image into docs-mcp/data (stop docs:serve first)'",
    "size-limit": "size-limit",
    "export": "node scripts/export.mjs",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm turbo build && changeset publish",
    "prepare": "husky"
  },
  "size-limit": [
    {
      "name": "@nexus_ds/react (ESM)",
      "path": "packages/react/dist/index.mjs",
      "ignore": [
        "@nexus_ds/core",
        "embla-carousel-react",
        "react-day-picker",
        "react-hook-form",
        "react-resizable-panels",
        "recharts",
        "sonner",
        "vaul"
      ],
      "limit": "95 kB"
    },
    {
      "name": "@nexus_ds/react (CSS)",
      "path": "packages/react/dist/react.css",
      "limit": "30 kB"
    },
    {
      "name": "@nexus_ds/react/appearance (ESM)",
      "path": "packages/react/dist/appearance.mjs",
      "ignore": [
        "@nexus_ds/core",
        "react",
        "react-dom"
      ],
      "limit": "45 kB"
    }
  ],
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^9.39.2",
    "@nexus_ds/eslint-plugin": "workspace:*",
    "@size-limit/preset-small-lib": "^12.0.0",
    "@storybook/addon-vitest": "^10.1.11",
    "@vitest/browser": "4.0.18",
    "@vitest/browser-playwright": "4.0.18",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jsdom": "^27.3.0",
    "jsonc-eslint-parser": "^3.1.0",
    "lint-staged": "^16.2.7",
    "playwright": "^1.57.0",
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-hook-form": "^7.77.0",
    "size-limit": "^12.0.0",
    "sonner": "^2.0.7",
    "turbo": "^2.7.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.0",
    "vitest": "4.0.18"
  },
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=20.19.0"
  },
  "browserslist": [
    "Chrome >= 111",
    "Edge >= 111",
    "Firefox >= 113",
    "Safari >= 15.4",
    "Samsung >= 22"
  ],
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ],
    "packages/core/tokens/semantic/spacing-*.json": [
      "pnpm validate:spacing-modes",
      "eslint --fix --no-warn-ignored"
    ],
    "packages/core/tokens/primitives/{radius,borderwidth,shadow}/*.json": [
      "pnpm validate:spacing-modes"
    ],
    "packages/core/tokens/**/*.json": [
      "pnpm audit:mode-codenames",
      "pnpm audit:mode-distinctness"
    ]
  },
  "pnpm": {
    "//overrides": "zod is pinned to dedupe @hookform/resolvers' broad peer range (^3.25.0 || ^4.0.0) onto a single v4 copy, so zodResolver() typechecks in Form.stories.tsx. zod is a story-only devDependency and ships in no package bundle. @radix-ui/react-context is deduped to 1.1.3 (react-menubar pins 1.1.2) so a single, top-level-nameable copy exists — otherwise the .d.ts rollup fails with TS2742 under pnpm.",
    "overrides": {
      "minimatch": "^10.1.2",
      "zod": "^4.4.3",
      "@radix-ui/react-context": "1.1.3"
    }
  }
}
