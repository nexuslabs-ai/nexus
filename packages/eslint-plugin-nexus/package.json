{
  "name": "@nexus_ds/eslint-plugin",
  "version": "0.2.0",
  "type": "module",
  "description": "Custom ESLint rules for the Nexus design system",
  "engines": {
    "node": ">=20.19.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nexuslabs-ai/nexus.git",
    "directory": "packages/eslint-plugin-nexus"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./config": "./src/config.js"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "refresh:canonical-set": "node scripts/refresh-canonical-set.js"
  },
  "dependencies": {
    "jsonc-eslint-parser": "^3.1.0"
  },
  "license": "MIT"
}
