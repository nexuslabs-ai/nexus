{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "W3C DTCG Design Tokens",
  "description": "JSON Schema for W3C Design Tokens Community Group format (v2025.10)",
  "type": "object",
  "patternProperties": {
    "^\\$?[a-zA-Z_][a-zA-Z0-9_-]*$": {
      "oneOf": [
        {
          "$ref": "#/definitions/token"
        },
        {
          "$ref": "#/definitions/group"
        }
      ]
    }
  },
  "definitions": {
    "token": {
      "type": "object",
      "required": ["$value", "$type"],
      "properties": {
        "$value": {
          "description": "The value of the token"
        },
        "$type": {
          "type": "string",
          "enum": [
            "color",
            "dimension",
            "fontFamily",
            "fontWeight",
            "duration",
            "cubicBezier",
            "number",
            "shadow",
            "typography",
            "border",
            "transition",
            "gradient",
            "strokeStyle"
          ],
          "description": "The type of the token"
        },
        "$description": {
          "type": "string",
          "description": "Optional description of the token"
        },
        "$extensions": {
          "type": "object",
          "description": "Optional custom extensions"
        }
      },
      "additionalProperties": false
    },
    "group": {
      "type": "object",
      "description": "A group of tokens or nested groups",
      "patternProperties": {
        "^\\$?[a-zA-Z_][a-zA-Z0-9_-]*$": {
          "oneOf": [
            {
              "$ref": "#/definitions/token"
            },
            {
              "$ref": "#/definitions/group"
            }
          ]
        }
      },
      "properties": {
        "$description": {
          "type": "string"
        },
        "$extensions": {
          "type": "object"
        }
      }
    }
  }
}
