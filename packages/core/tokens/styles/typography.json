{
  "heading": {
    "large": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{family.font-heading}",
        "fontSize": "{size.3xl}",
        "fontWeight": "{weight.bold}",
        "lineHeight": "{line-height.3xl}",
        "letterSpacing": "{letterspacing.tighter}"
      },
      "$description": "Major section heading, dialog titles, card group headers"
    },
    "medium": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{family.font-heading}",
        "fontSize": "{size.2xl}",
        "fontWeight": "{weight.bold}",
        "lineHeight": "{line-height.2xl}",
        "letterSpacing": "{letterspacing.tight}"
      },
      "$description": "Susbsection heading, card titles, modal headers"
    },
    "small": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{family.font-heading}",
        "fontSize": "{size.xl}",
        "fontWeight": "{weight.bold}",
        "lineHeight": "{line-height.xl}",
        "letterSpacing": "{letterspacing.tight}"
      },
      "$description": "Card Titles, list section headers, minor heading"
    },
    "xsmall": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{family.font-heading}",
        "fontSize": "{size.lg}",
        "fontWeight": "{weight.bold}",
        "lineHeight": "{line-height.lg}",
        "letterSpacing": "{letterspacing.tight}"
      },
      "$description": "Table Section headers, accordian titles, minor seciton lables"
    },
    "xxsmall": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{family.font-heading}",
        "fontSize": "{size.base}",
        "fontWeight": "{weight.semibold}",
        "lineHeight": "{line-height.base}",
        "letterSpacing": "{letterspacing.tight}"
      },
      "$description": "Smallest heading tier — empty-state titles, compact card headers"
    }
  },
  "body": {
    "default": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{family.font-sans}",
        "fontSize": "{size.sm}",
        "fontWeight": "{weight.normal}",
        "lineHeight": "{line-height.sm}",
        "letterSpacing": "{letterspacing.normal}"
      },
      "$description": "Default Paragraph text, description, card content, main body copy 14"
    },
    "small": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{family.font-sans}",
        "fontSize": "{size.xs}",
        "fontWeight": "{weight.normal}",
        "lineHeight": "{line-height.xs}",
        "letterSpacing": "{letterspacing.normal}"
      },
      "$description": "12"
    }
  },
  "shortcut": {
    "$type": "typography",
    "$value": {
      "fontFamily": "{family.font-sans}",
      "fontSize": "{size.xs}",
      "fontWeight": "{weight.normal}",
      "lineHeight": "{line-height.xs}",
      "letterSpacing": "{letterspacing.widest}"
    },
    "$description": "Keyboard shortcut hint text in command palettes, menus, and menubars"
  },
  "label": {
    "default": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{family.font-sans}",
        "fontSize": "{size.sm}",
        "fontWeight": "{weight.medium}",
        "lineHeight": "{line-height.sm}",
        "letterSpacing": "{letterspacing.normal}"
      },
      "$description": "14"
    },
    "small": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{family.font-sans}",
        "fontSize": "{size.xs}",
        "fontWeight": "{weight.medium}",
        "lineHeight": "{line-height.xs}",
        "letterSpacing": "{letterspacing.normal}"
      },
      "$description": "12"
    },
    "caps": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{family.font-sans}",
        "fontSize": "{size.xxs}",
        "fontWeight": "{weight.semibold}",
        "lineHeight": "{line-height.xs}",
        "letterSpacing": "{letterspacing.wide}"
      },
      "$description": "12"
    }
  },
  "code": {
    "block": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{family.font-mono}",
        "fontSize": "{size.sm}",
        "fontWeight": "{weight.normal}",
        "lineHeight": "{line-height.sm}",
        "letterSpacing": {
          "value": 0,
          "unit": "px"
        }
      }
    },
    "inline": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{family.font-mono}",
        "fontSize": "{size.sm}",
        "fontWeight": "{weight.semibold}",
        "lineHeight": "auto",
        "letterSpacing": {
          "value": 0,
          "unit": "px"
        }
      }
    }
  }
}
