# =============================================================================
# Context Engine - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# cp env.example .env

# =============================================================================
# Server Configuration
# =============================================================================
PORT=3000
NODE_ENV=development

# =============================================================================
# Database Configuration (PostgreSQL + pgvector)
# =============================================================================
# Local development (Docker)
DATABASE_URL=postgres://context_engine:context_engine_dev@localhost:5432/context_engine

# Production examples:
# Supabase: postgres://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Neon: postgres://[user]:[password]@[endpoint].neon.tech/context_engine?sslmode=require
# Railway: postgres://[user]:[password]@[host].railway.app:5432/railway

# Connection pool settings
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# =============================================================================
# Embedding Configuration
# =============================================================================
# Voyage AI for embeddings
VOYAGE_API_KEY=your-voyage-api-key
VOYAGE_MODEL=voyage-code-3
VOYAGE_DIMENSIONS=1024

# =============================================================================
# LLM Configuration (for meta generation)
# =============================================================================
ANTHROPIC_API_KEY=your-anthropic-api-key

# Model to use for generation
# Options:
#   - claude-opus-4-5-20251101 (latest, best quality, $5/$25 per MTok)
#   - claude-sonnet-4-20250514 (balanced, recommended for most use cases)
#   - claude-haiku-3-20240307  (fastest, lowest cost)
# Default: claude-sonnet-4-20250514
CONTEXT_ENGINE_MODEL=claude-sonnet-4-20250514

# Maximum tokens for LLM completion
# Default: 8192
CONTEXT_ENGINE_MAX_TOKENS=8192

# Request timeout in milliseconds
# Default: 180000 (3 minutes)
CONTEXT_ENGINE_TIMEOUT_MS=180000

# Base URL override (for proxies or custom endpoints)
# ANTHROPIC_BASE_URL=

# =============================================================================
# Generation Settings (@context-engine/core)
# =============================================================================
# Maximum tokens specifically for metadata generation
# Default: 8192
CONTEXT_ENGINE_GENERATION_MAX_TOKENS=8192

# Semantic description length constraints (for embedding search)
CONTEXT_ENGINE_MIN_SEMANTIC_DESC_LENGTH=50
CONTEXT_ENGINE_MAX_SEMANTIC_DESC_LENGTH=2000

# Component description length constraints
CONTEXT_ENGINE_MIN_DESC_LENGTH=10
CONTEXT_ENGINE_MAX_DESC_LENGTH=500

# =============================================================================
# Feature Flags (@context-engine/core)
# =============================================================================
# Skip LLM generation (extraction only mode)
# CONTEXT_ENGINE_SKIP_GENERATION=false

# Enable debug mode
# CONTEXT_ENGINE_DEBUG=false

# =============================================================================
# Authentication Configuration
# =============================================================================
# Enable authentication (false for local development)
AUTH_ENABLED=false

# Development credentials (only used when AUTH_ENABLED=false)
DEV_API_KEY=dev_token
DEV_ORG_ID=dev

# JWT secret for session tokens (production)
# JWT_SECRET=your-jwt-secret

# =============================================================================
# Rate Limiting Configuration
# =============================================================================
# Requests per minute per org (0 = unlimited)
RATE_LIMIT_RPM=60

# Extraction requests per minute (separate limit)
EXTRACT_RATE_LIMIT_RPM=30

# Generate requests per minute (LLM calls, most expensive)
GENERATE_RATE_LIMIT_RPM=10

# =============================================================================
# Background Processing Configuration
# =============================================================================
# Embedding processor interval (ms)
EMBEDDING_PROCESSOR_INTERVAL=5000

# Max concurrent embedding operations
EMBEDDING_CONCURRENCY=3

# Embedding retry attempts
EMBEDDING_MAX_RETRIES=3

# =============================================================================
# Logging Configuration
# =============================================================================
# Log level: debug, info, warn, error
LOG_LEVEL=info

# @context-engine/core specific logging
# CONTEXT_ENGINE_LOG_LEVEL=info
# CONTEXT_ENGINE_LOG_JSON=false
