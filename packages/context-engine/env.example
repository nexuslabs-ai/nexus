# =============================================================================
# Context Engine - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# cp env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Provider - Choose ONE provider
# -----------------------------------------------------------------------------

# Option 1: Anthropic Claude (Recommended - Best quality)
# Get API key at: https://console.anthropic.com
ANTHROPIC_API_KEY=
CONTEXT_ENGINE_PROVIDER=anthropic
CONTEXT_ENGINE_MODEL=claude-opus-4-5-20251101

# Option 2: Google Gemini (Alternative)
# Get your API key at: https://aistudio.google.com/apikey
# GOOGLE_API_KEY=
# CONTEXT_ENGINE_PROVIDER=gemini
# CONTEXT_ENGINE_MODEL=gemini-2.5-flash

CONTEXT_ENGINE_MAX_TOKENS=8192
CONTEXT_ENGINE_TIMEOUT_MS=180000

# -----------------------------------------------------------------------------
# Generation Configuration
# -----------------------------------------------------------------------------
CONTEXT_ENGINE_GENERATION_MAX_TOKENS=8192
CONTEXT_ENGINE_MIN_SEMANTIC_DESC_LENGTH=50
CONTEXT_ENGINE_MAX_SEMANTIC_DESC_LENGTH=2000
CONTEXT_ENGINE_MIN_DESC_LENGTH=10
CONTEXT_ENGINE_MAX_DESC_LENGTH=500

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
CONTEXT_ENGINE_ENABLE_CACHING=false
CONTEXT_ENGINE_ENABLE_METRICS=false

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
CONTEXT_ENGINE_LOG_LEVEL=info
CONTEXT_ENGINE_LOG_JSON=false
