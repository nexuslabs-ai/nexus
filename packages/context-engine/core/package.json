{
  "name": "@context-engine/core",
  "version": "0.1.0",
  "description": "Shared types, schemas, and utilities for Context Engine",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js",
      "require": "./dist/config/index.cjs"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js",
      "require": "./dist/types/index.cjs"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js",
      "require": "./dist/utils/index.cjs"
    },
    "./extractor": {
      "types": "./dist/extractor/index.d.ts",
      "import": "./dist/extractor/index.js",
      "require": "./dist/extractor/index.cjs"
    },
    "./generator": {
      "types": "./dist/generator/index.d.ts",
      "import": "./dist/generator/index.js",
      "require": "./dist/generator/index.cjs"
    },
    "./manifest": {
      "types": "./dist/manifest/index.d.ts",
      "import": "./dist/manifest/index.js",
      "require": "./dist/manifest/index.cjs"
    },
    "./processor": {
      "types": "./dist/processor/index.d.ts",
      "import": "./dist/processor/index.js",
      "require": "./dist/processor/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ test/ --ext .ts",
    "test": "USE_CACHED=true vitest run",
    "test:watch": "USE_CACHED=true vitest",
    "test:ui": "USE_CACHED=true vitest --ui",
    "test:real": "vitest run test/integration/real-llm.test.ts",
    "test:record": "RECORD_RESPONSES=true vitest run test/integration/real-llm.test.ts",
    "test:validate": "VALIDATE_LLM=true vitest run test/integration/real-llm.test.ts",
    "test:record-all": "tsx scripts/record-responses.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@google/generative-ai": "^0.24.1",
    "fast-json-stable-stringify": "^2.1.0",
    "react-docgen-typescript": "^2.2.2",
    "semver": "^7.6.0",
    "ts-morph": "^25.0.1",
    "uuid": "^9.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/semver": "^7.5.0",
    "@types/uuid": "^9.0.0",
    "@vitest/ui": "4.0.17",
    "dotenv": "^17.2.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "4.0.17"
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  }
}
