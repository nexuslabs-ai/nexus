  "manifest": {
    "name": "Tooltip",
    "slug": "tooltip-react-3b0ab7c2",
    "description": "The Tooltip component provides a discreet and non-disruptive way to display additional information or labels when a user interacts with an element. It's ideal for clarifying icons, explaining truncated text, or providing hints for form fields. Key features include its transient nature, appearing on hover or focus and disappearing when the interaction ends, and its ability to prevent UI clutter. Use cases include explaining the function of an icon-only button, providing a full text for truncated labels, or giving quick guidance for complex controls.",
    "importStatement": {
      "primary": "import { Tooltip, TooltipContent, TooltipProvider, TooltipTrigger } from '@nexus/react'",
      "typeOnly": "import type { TooltipProps } from '@nexus/react'"
    },
    "examples": {
      "minimal": {
        "title": "Default",
        "code": "(\n    <Tooltip>\n      <TooltipTrigger asChild>\n        <Button variant=\"outline\">Hover me</Button>\n      </TooltipTrigger>\n      <TooltipContent>\n        <p>This is a tooltip</p>\n      </TooltipContent>\n    </Tooltip>\n  )",
        "isPrimary": true
      },
      "common": [
        {
          "title": "Side Top",
          "code": "(\n    <Tooltip>\n      <TooltipTrigger asChild>\n        <Button variant=\"outline\">Top</Button>\n      </TooltipTrigger>\n      <TooltipContent side=\"top\">\n        <p>Tooltip on top</p>\n      </TooltipContent>\n    </Tooltip>\n  )"
        },
        {
          "title": "Side Right",
          "code": "(\n    <Tooltip>\n      <TooltipTrigger asChild>\n        <Button variant=\"outline\">Right</Button>\n      </TooltipTrigger>\n      <TooltipContent side=\"right\">\n        <p>Tooltip on right</p>\n      </TooltipContent>\n    </Tooltip>\n  )"
        },
        {
          "title": "Side Bottom",
          "code": "(\n    <Tooltip>\n      <TooltipTrigger asChild>\n        <Button variant=\"outline\">Bottom</Button>\n      </TooltipTrigger>\n      <TooltipContent side=\"bottom\">\n        <p>Tooltip on bottom</p>\n      </TooltipContent>\n    </Tooltip>\n  )"
        },
        {
          "title": "Side Left",
          "code": "(\n    <Tooltip>\n      <TooltipTrigger asChild>\n        <Button variant=\"outline\">Left</Button>\n      </TooltipTrigger>\n      <TooltipContent side=\"left\">\n        <p>Tooltip on left</p>\n      </TooltipContent>\n    </Tooltip>\n  )"
        },
        {
          "title": "With Long Content",
          "code": "(\n    <Tooltip>\n      <TooltipTrigger asChild>\n        <Button variant=\"outline\">Hover for details</Button>\n      </TooltipTrigger>\n      <TooltipContent className=\"nx:max-w-xs\">\n        <p>\n          This tooltip contains longer content that might wrap to multiple lines\n          when it exceeds the maximum width.\n        </p>\n      </TooltipContent>\n    </Tooltip>\n  )"
        },
        {
          "title": "With Custom Offset",
          "code": "(\n    <Tooltip>\n      <TooltipTrigger asChild>\n        <Button variant=\"outline\">Custom offset</Button>\n      </TooltipTrigger>\n      <TooltipContent sideOffset={12}>\n        <p>12px offset from trigger</p>\n      </TooltipContent>\n    </Tooltip>\n  )"
        }
      ]
    },
    "guidance": {
      "whenToUse": "Use tooltips to provide supplementary information or context for interactive elements, icons, or truncated text when space is limited and the information is not critical for immediate task completion. They enhance usability by clarifying the purpose of an element without cluttering the UI.",
      "whenNotToUse": "Avoid using tooltips for essential information that users need to see immediately, for long blocks of text, or for actions that require user interaction within the tooltip itself. Use popovers, modals, or inline text for critical information or interactive content.",
      "accessibility": "Ensure tooltips are keyboard accessible, appearing on focus and disappearing on blur. Provide clear ARIA attributes (e.g., `aria-describedby` or `aria-label`) to link the tooltip content to its trigger element for screen reader users. The content should be concise and meaningful.",
      "patterns": ["overlay", "data-display"],
      "relatedComponents": ["Button"]
    },
