  "manifest": {
    "name": "Switch",
    "slug": "switch-react-9c533ca7",
    "description": "The Switch component provides an intuitive toggle mechanism for binary states (e.g., on/off, enabled/disabled). It's designed for user settings or preferences that, when changed, apply their effect instantly without requiring an explicit 'save' action. Key features include its clear visual feedback, immediate state changes upon interaction, and adherence to accessibility standards for interactive form controls. Common use cases involve toggling notifications, activating dark mode, enabling feature flags, or any simple binary configuration within an application. It's built on Radix UI, ensuring robust accessibility and behavior.",
    "importStatement": {
      "primary": "import { Switch } from '@nexus/react'",
      "typeOnly": "import type { SwitchProps } from '@nexus/react'"
    },
    "props": {
      "other": [
        {
          "name": "asChild",
          "type": "boolean",
          "required": false
        }
      ]
    },
    "examples": {
      "minimal": {
        "title": "Default",
        "code": "<Switch 'aria-label'=\"Toggle switch\" />",
        "isPrimary": true
      },
      "common": [
        {
          "title": "Checked",
          "code": "<Switch 'aria-label'=\"Toggle switch\" defaultChecked />"
        },
        {
          "title": "Disabled",
          "code": "<Switch 'aria-label'=\"Toggle switch\" disabled />"
        },
        {
          "title": "Disabled Checked",
          "code": "<Switch 'aria-label'=\"Toggle switch\" disabled defaultChecked />"
        },
        {
          "title": "With Label",
          "code": "(\n    <div className=\"nx:flex nx:items-center nx:gap-2\">\n      <Switch id=\"airplane-mode\" />\n      <label\n        htmlFor=\"airplane-mode\"\n        className=\"nx:text-sm nx:font-medium nx:leading-none nx:peer-disabled:cursor-not-allowed nx:peer-disabled:opacity-70\"\n      >\n        Airplane Mode\n      </label>\n    </div>\n  )"
        },
        {
          "title": "With Label And Description",
          "code": "(\n    <div className=\"nx:flex nx:items-start nx:gap-3\">\n      <Switch id=\"notifications\" className=\"nx:mt-0.5\" />\n      <div className=\"nx:grid nx:gap-1.5\">\n        <label\n          htmlFor=\"notifications\"\n          className=\"nx:text-sm nx:font-medium nx:leading-none\"\n        >\n          Enable Notifications\n        </label>\n        <p className=\"nx:text-sm nx:text-muted-foreground\">\n          Receive notifications when someone mentions you.\n        </p>\n      </div>\n    </div>\n  )"
        },
        {
          "title": "Label On Left",
          "code": "(\n    <div className=\"nx:flex nx:items-center nx:justify-between nx:gap-4 nx:rounded-lg nx:border nx:border-border-default nx:p-4\">\n      <div className=\"nx:space-y-0.5\">\n        <label\n          htmlFor=\"marketing\"\n          className=\"nx:text-sm nx:font-medium nx:leading-none\"\n        >\n          Marketing emails\n        </label>\n        <p className=\"nx:text-sm nx:text-muted-foreground\">\n          Receive emails about new products and features.\n        </p>\n      </div>\n      <Switch id=\"marketing\" />\n    </div>\n  )"
        },
        {
          "title": "Controlled",
          "code": "<div className=\"nx:flex nx:flex-col nx:items-center nx:gap-4\">\n        <div className=\"nx:flex nx:items-center nx:gap-2\">\n          <Switch\n            id=\"controlled\"\n            checked={checked}\n            onCheckedChange={setChecked}\n          />\n          <label htmlFor=\"controlled\" className=\"nx:text-sm nx:font-medium\">\n            Controlled Switch\n          </label>\n        </div>\n        <p className=\"nx:text-sm nx:text-muted-foreground\">\n          Switch is {checked ? 'on' : 'off'}\n        </p>\n      </div>"
        }
      ]
    },
    "guidance": {
      "whenToUse": "Use for settings that take effect immediately without requiring a save action, providing a clear binary choice like 'on' or 'off'. Ideal for preferences that need instant application.",
      "whenNotToUse": "Do not use for actions that require a confirmation step, have complex implications, or where multiple selections are possible. For mutually exclusive options, consider RadioGroup; for multiple independent selections, use Checkbox.",
      "accessibility": "Ensures proper ARIA attributes for a switch role, indicating its checked or unchecked state to assistive technologies. Supports keyboard interaction (Spacebar to toggle, Tab to focus) and integrates well with screen readers to announce its label and current state.",
