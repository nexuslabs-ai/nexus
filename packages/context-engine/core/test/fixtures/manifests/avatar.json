  "manifest": {
    "name": "Avatar",
    "slug": "avatar-react-bcbed065",
    "description": "The Avatar component provides a flexible and accessible way to display visual identifiers for users or entities. It supports displaying a profile image, with robust fallback mechanisms to initials generated from a name, or a generic placeholder icon if neither an image nor initials are available. Key features include customizable 'size' (ranging from '2xs' to '4xl') and 'shape' ('circle' or 'rounded'), allowing it to adapt to diverse design contexts. It's built on `@radix-ui/react-avatar` for solid accessibility and behavior, ensuring a consistent user experience across applications. Common use cases include user profile sections, comment threads, team directories, and social media feeds, where a compact visual representation of an individual or organization is needed.",
    "importStatement": {
      "primary": "import { Avatar, AvatarFallback, AvatarImage } from '@nexus/react'",
      "typeOnly": "import type { AvatarProps } from '@nexus/react'"
    },
    "props": {
      "variants": [
        {
          "name": "size",
          "type": "string",
          "defaultValue": "md",
          "values": ["2xs", "xs", "sm", "md", "lg", "xl", "2xl", "3xl", "4xl"],
          "required": false,
          "valueDescriptions": {
            "2xs": "Extra extra small size, for compact displays.",
            "xs": "Extra small size.",
            "sm": "Small size.",
            "md": "Medium size (default).",
            "lg": "Large size.",
            "xl": "Extra large size.",
            "2xl": "Extra extra large size.",
            "3xl": "Triple extra large size.",
            "4xl": "Quadruple extra large size, for prominent displays."
          }
        },
        {
          "name": "shape",
          "type": "string",
          "defaultValue": "circle",
          "values": ["circle", "rounded"],
          "required": false,
          "valueDescriptions": {
            "circle": "A perfectly round avatar (default).",
            "rounded": "A square avatar with rounded corners."
          }
        }
      ],
      "other": [
        {
          "name": "asChild",
          "type": "boolean",
          "required": false
        }
      ]
    },
