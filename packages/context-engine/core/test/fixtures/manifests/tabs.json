  "manifest": {
    "name": "Tabs",
    "slug": "tabs-react-4775a2f0",
    "description": "The Tabs component is a fundamental UI element designed to organize and separate related content into distinct, switchable sections within a single view. It provides a structured way to present large amounts of information without overwhelming the user, improving readability and user experience. Key features include state management for active tabs, logical grouping of content panels, and intuitive navigation between sections. Tabs are commonly used in various application contexts such as user profile settings, product detail pages (e.g., description, reviews, specifications), data dashboards with different analytical views, or multi-step forms where each step is a tab. It acts as a container for `TabList`, `Tab`, and `TabPanel` sub-components, managing their interaction and ensuring only the content of the currently active tab is visible.",
    "importStatement": {
      "primary": "import { Tabs, TabsContent, TabsList, TabsTrigger } from '@nexus/react'",
      "typeOnly": "import type { TabsProps } from '@nexus/react'"
    },
