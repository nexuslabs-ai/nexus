          "name": "asChild",
          "type": "boolean",
          "required": false
        }
      ]
    },
    "examples": {
      "minimal": {
        "title": "Default",
        "code": "(\n    <Tabs defaultValue=\"account\" className=\"nx:w-[400px]\">\n      <TabsList>\n        <TabsTrigger value=\"account\">Account</TabsTrigger>\n        <TabsTrigger value=\"password\">Password</TabsTrigger>\n      </TabsList>\n      <TabsContent value=\"account\">\n        <p className=\"nx:text-sm nx:text-muted-foreground\">\n          Make changes to your account here. Click save when you&apos;re done.\n        </p>\n      </TabsContent>\n      <TabsContent value=\"password\">\n        <p className=\"nx:text-sm nx:text-muted-foreground\">\n          Change your password here. After saving, you&apos;ll be logged out.\n        </p>\n      </TabsContent>\n    </Tabs>\n  )",
        "isPrimary": true
      },
      "common": [
        {
          "title": "With Cards",
          "code": "(\n    <Tabs defaultValue=\"account\" className=\"nx:w-[400px]\">\n      <TabsList className=\"nx:grid nx:w-full nx:grid-cols-2\">\n        <TabsTrigger value=\"account\">Account</TabsTrigger>\n        <TabsTrigger value=\"password\">Password</TabsTrigger>\n      </TabsList>\n      <TabsContent value=\"account\">\n        <Card>\n          <CardHeader>\n            <CardTitle>Account</CardTitle>\n            <CardDescription>\n              Make changes to your account here. Click save when you&apos;re\n              done.\n            </CardDescription>\n          </CardHeader>\n          <CardContent className=\"nx:space-y-2\">\n            <div className=\"nx:space-y-1\">\n              <label\n                htmlFor=\"name\"\n                className=\"nx:text-sm nx:font-medium nx:leading-none\"\n              >\n                Name\n              </label>\n              <Input id=\"name\" defaultValue=\"Pedro Duarte\" />\n            </div>\n            <div className=\"nx:space-y-1\">\n              <label\n                htmlFor=\"username\"\n                className=\"nx:text-sm nx:font-medium nx:leading-none\"\n              >\n                Username\n              </label>\n              <Input id=\"username\" defaultValue=\"@peduarte\" />\n            </div>\n          </CardContent>\n        </Card>\n      </TabsContent>\n      <TabsContent value=\"password\">\n        <Card>\n          <CardHeader>\n            <CardTitle>Password</CardTitle>\n            <CardDescription>\n              Change your password here. After saving, you&apos;ll be logged\n              out.\n            </CardDescription>\n          </CardHeader>\n          <CardContent className=\"nx:space-y-2\">\n            <div className=\"nx:space-y-1\">\n              <label\n                htmlFor=\"current\"\n                className=\"nx:text-sm nx:font-medium nx:leading-none\"\n              >\n                Current password\n              </label>\n              <Input id=\"current\" type=\"password\" />\n            </div>\n            <div className=\"nx:space-y-1\">\n              <label\n                htmlFor=\"new\"\n                className=\"nx:text-sm nx:font-medium nx:leading-none\"\n              >\n                New password\n              </label>\n              <Input id=\"new\" type=\"password\" />\n            </div>\n          </CardContent>\n        </Card>\n      </TabsContent>\n    </Tabs>\n  )"
        },
        {
          "title": "Three Tabs",
          "code": "(\n    <Tabs defaultValue=\"overview\" className=\"nx:w-[500px]\">\n      <TabsList>\n        <TabsTrigger value=\"overview\">Overview</TabsTrigger>\n        <TabsTrigger value=\"analytics\">Analytics</TabsTrigger>\n        <TabsTrigger value=\"reports\">Reports</TabsTrigger>\n      </TabsList>\n      <TabsContent value=\"overview\">\n        <p className=\"nx:text-sm nx:text-muted-foreground\">\n          Overview of your dashboard metrics and key performance indicators.\n        </p>\n      </TabsContent>\n      <TabsContent value=\"analytics\">\n        <p className=\"nx:text-sm nx:text-muted-foreground\">\n          Detailed analytics showing user engagement and traffic patterns.\n        </p>\n      </TabsContent>\n      <TabsContent value=\"reports\">\n        <p className=\"nx:text-sm nx:text-muted-foreground\">\n          Generated reports for stakeholders and team reviews.\n        </p>\n      </TabsContent>\n    </Tabs>\n  )"
        },
        {
