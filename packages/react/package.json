{
  "name": "@nexus_ds/react",
  "version": "0.1.0",
  "private": true,
  "description": "React components built with Radix UI and Tailwind CSS",
  "//": [
    "@nexus_ds/core is a runtime dependency of @nexus_ds/react/appearance; Vite marks it external so the runtime theme engine is consumed from @nexus_ds/core, not bundled into @nexus_ds/react.",
    "Tracked for restructure: https://github.com/nexuslabs-ai/nexus/issues/66 (move to @nexus_ds/tailwind dependsOn @nexus_ds/core#build:tailwind in turbo)."
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./appearance": {
      "types": "./dist/components/appearance/provider/index.d.ts",
      "import": "./dist/appearance.mjs",
      "require": "./dist/appearance.js"
    },
    "./appearance/server": {
      "types": "./dist/components/appearance/provider/server.d.ts",
      "import": "./dist/appearance-server.mjs",
      "require": "./dist/appearance-server.js"
    },
    "./styles.css": "./dist/react.css"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.1.10",
    "@storybook/addon-docs": "^10.1.10",
    "@storybook/react-vite": "^10.1.10",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "embla-carousel-react": "^8.6.0",
    "react-day-picker": "^9",
    "react-resizable-panels": "^4.11.2",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "storybook": "^10.1.10",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vaul": "^1.1.2",
    "vite": "^7.3.0",
    "vite-plugin-dts": "^5.0.3"
  },
  "dependencies": {
    "@nexus_ds/core": "workspace:*",
    "@nexus_ds/tailwind": "workspace:*",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tabler/icons-react": "^3.36.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "input-otp": "^1.4.2",
    "tailwind-merge": "^3.4.0"
  },
  "peerDependencies": {
    "embla-carousel-react": "^8.6.0",
    "react": "^19.0.0",
    "react-day-picker": "^9",
    "react-dom": "^19.0.0",
    "react-resizable-panels": "^4.11.2",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "vaul": "^1.1.2"
  },
  "peerDependenciesMeta": {
    "embla-carousel-react": {
      "optional": true
    },
    "react-day-picker": {
      "optional": true
    },
    "react-resizable-panels": {
      "optional": true
    },
    "recharts": {
      "optional": true
    },
    "vaul": {
      "optional": true
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "license": "MIT"
}
